module Write

import Kraken.Db
import Kraken.Db.Dml
import Kraken.Db.Dml (Update)
import Kraken.Db.Query (Prepared, Repo, DbError, QueryFailed)
import Kraken.Db.Query as Query
import Read (users, User, UsersInsert)
import SagaPgo (Connection, Postgres, Transaction, QueryError)

# INSERT using the schema-generated insert type. Generated id via Db.auto.
pub fun insert_user_query : Unit -> Prepared Unit
insert_user_query () =
  Dml.insert users (UsersInsert { id: Db.auto, name: "Carol", age: 31 })

# INSERT ... RETURNING the whole inserted row, decoded back into the domain type.
pub fun insert_user_returning : Unit -> Prepared User
insert_user_returning () = {
  let row = UsersInsert { id: Db.auto, name: "Carol", age: 31 }
  Dml.insert_returning users row (fun u -> u)
}

# INSERT ... RETURNING just the generated id (the common "get my new id" case).
pub fun insert_user_returning_id : Unit -> Prepared { id: Int }
insert_user_returning_id () = {
  let row = UsersInsert { id: Db.auto, name: "Carol", age: 31 }
  Dml.insert_returning users row (fun u -> { id: u.id })
}

# UPDATE ... RETURNING the updated row.
pub fun bump_age_returning : Unit -> Prepared User
bump_age_returning () = Dml.update_returning users (fun u -> {
  set! u.age 43
  where_! (Db.eq u.id 1)
}) (fun u -> u)

# Run an INSERT ... RETURNING and decode the single row back.
pub fun run_insert_returning : Connection -> Result (Maybe User) DbError needs {Repo}
run_insert_returning conn = Query.one conn (insert_user_returning ())

# Upsert: insert, or on a primary-key collision overwrite name/age with the new
# values. Provides the id so the conflict can actually fire.
pub fun upsert_user_query : Unit -> Prepared Unit
upsert_user_query () = {
  let row = UsersInsert { id: Db.provide 1, name: "Carol", age: 31 }
  Dml.upsert users row (fun u -> [Db.ref u.id])
}

# Insert-or-skip: do nothing if a row with this name already exists.
pub fun insert_user_if_new_query : Unit -> Prepared Unit
insert_user_if_new_query () = {
  let row = UsersInsert { id: Db.auto, name: "Carol", age: 31 }
  Dml.insert_on_conflict_do_nothing users row (fun u -> [Db.ref u.name])
}

# Upsert and read back the resulting row (inserted or updated).
pub fun upsert_user_returning : Unit -> Prepared User
upsert_user_returning () = {
  let row = UsersInsert { id: Db.provide 1, name: "Carol", age: 31 }
  Dml.upsert_returning users row (fun u -> [Db.ref u.id]) (fun u -> u)
}

# Insert-if-new and read back the row (Nothing on conflict, since a skipped row
# returns nothing).
pub fun insert_user_if_new_returning : Unit -> Prepared User
insert_user_if_new_returning () = {
  let row = UsersInsert { id: Db.auto, name: "Carol", age: 31 }
  Dml.insert_on_conflict_do_nothing_returning users row (fun u -> [Db.ref u.name]) (fun u -> u)
}

# Run an upsert-returning and decode the resulting row.
pub fun run_upsert_returning : Connection -> Result (Maybe User) DbError needs {Repo}
run_upsert_returning conn = Query.one conn (upsert_user_returning ())

# Atomic multi-statement write: insert a user and bump another's age in one
# transaction. Both commit together, or — if either op fails — both roll back.
# Returns the total number of affected rows. Only Postgres + Transaction need
# handlers; the body's Repo capability is provided by `transaction` itself.
pub fun atomic_writes : Connection -> Result Int DbError needs {Postgres, Transaction}
atomic_writes conn = Query.transaction conn (fun () -> {
  let new_row = UsersInsert { id: Db.auto, name: "Dave", age: 40 }
  case Dml.exec conn (Dml.insert users new_row) {
    Err err -> Err err
    Ok inserted -> case Dml.exec conn (bump_age_query ()) {
      Err err -> Err err
      Ok bumped -> Ok (inserted + bumped)
    }
  }
})

# Rollback path: the INSERT itself succeeds, but the body returns Err, so the
# transaction rolls back and the row never persists.
pub fun rolled_back_write : Connection
  -> QueryError
  -> Result Unit DbError
  needs {Postgres, Transaction}
rolled_back_write conn abort = Query.transaction conn (fun () -> {
  let new_row = UsersInsert { id: Db.auto, name: "Ghost", age: 99 }
  case Dml.exec conn (Dml.insert users new_row) {
    Err err -> Err err
    Ok _ -> Err (QueryFailed abort)
  }
})

# Surgical UPDATE: only the columns that change.
pub fun bump_age_query : Unit -> Prepared Unit
bump_age_query () = Dml.update users (fun u -> {
  set! u.age 43
  where_! (Db.eq u.id 1)
})

# Whole-entity save: read -> modify -> save, keyed by primary_key
pub fun save_user_query : User -> Prepared Unit
save_user_query user = Dml.update_all users user

# DELETE with a predicate.
pub fun delete_user_query : Unit -> Prepared Unit
delete_user_query () = Dml.delete users (fun u -> Db.eq u.id 999)

pub fun run_bump_age : Connection -> Result Int DbError needs {Repo}
run_bump_age conn = Dml.exec conn (bump_age_query ())

pub fun run_delete_user : Connection -> Result Int DbError needs {Repo}
run_delete_user conn = Dml.exec conn (delete_user_query ())
