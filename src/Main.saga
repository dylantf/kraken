module Main

import Std.IO (console)
import Kraken.Query as Db
import Kraken.Query (QueryBuild, Repo)
import SagaPgo (Connection, connect, default_config, pg)

record User {
  id: Int,
  name: String,
  age: Int,
}

record NewUser {
  name: String,
  age: Int,
}

record Post {
  id: Int,
  author_id: Int,
  title: String,
  published: Bool,
}

record NewPost {
  author_id: Int,
  title: String,
  published: Bool,
}

type UsersScope = UsersScope
type PostsScope = PostsScope
type UsersTable = UsersTable
type PostsTable = PostsTable

record Users source {
  id: Db.Column source 'id Int,
  name: Db.Column source 'name String,
  age: Db.Column source 'age Int,
}

record OptionalUsers source {
  id: Db.Column source 'id (Maybe Int),
  name: Db.Column source 'name (Maybe String),
  age: Db.Column source 'age (Maybe Int),
}

record Posts source {
  id: Db.Column source 'id Int,
  author_id: Db.Column source 'author_id Int,
  title: Db.Column source 'title String,
  published: Db.Column source 'published Bool,
}

record OptionalPosts source {
  id: Db.Column source 'id (Maybe Int),
  author_id: Db.Column source 'author_id (Maybe Int),
  title: Db.Column source 'title (Maybe String),
  published: Db.Column source 'published (Maybe Bool),
}

fun user_cols : String -> Users UsersScope
user_cols source = Users {
  id: Db.col_as "id" source,
  name: Db.col_as "name" source,
  age: Db.col_as "age" source,
}

fun optional_user_cols : String -> OptionalUsers UsersScope
optional_user_cols source = OptionalUsers {
  id: Db.col_as "id" source,
  name: Db.col_as "name" source,
  age: Db.col_as "age" source,
}

fun post_cols : String -> Posts PostsScope
post_cols source = Posts {
  id: Db.col_as "id" source,
  author_id: Db.col_as "author_id" source,
  title: Db.col_as "title" source,
  published: Db.col_as "published" source,
}

fun optional_post_cols : String -> OptionalPosts PostsScope
optional_post_cols source = OptionalPosts {
  id: Db.col_as "id" source,
  author_id: Db.col_as "author_id" source,
  title: Db.col_as "title" source,
  published: Db.col_as "published" source,
}

fun users : Db.Table UsersTable User NewUser (Users UsersScope) (OptionalUsers UsersScope)
users = Db.table "users" user_cols optional_user_cols

fun posts : Db.Table PostsTable Post NewPost (Posts PostsScope) (OptionalPosts PostsScope)
posts = Db.table "posts" post_cols optional_post_cols

impl Db.Selectable User for Users source {
  to_projection u = {
    let projection: Db.Projection { id: Int, name: String, age: Int } =
      Db.project ({ id: u.id, name: u.name, age: u.age })
    projection
    |> Db.map (fun row -> User { id: row.id, name: row.name, age: row.age })
  }
}

fun users_query : Unit -> Db.Prepared { id: Int, name: String, age: Int }
users_query () = Db.query (fun () -> {
  let u = from! users
  where_! (Db.gt u.age 18)
  order_by! [Db.asc u.id]
  limit! 20
  select! ({ id: u.id, name: u.name, age: u.age })
})

fun post_count_query : Unit -> Db.Prepared { total: Int }
post_count_query () = Db.query (fun () -> {
  let p = from! posts
  where_! (Db.eq p.published True)
  select! ({ total: Db.count_star })
})

fun post_counts_by_author_query : Unit -> Db.Prepared {
  author_id: Int,
  total: Int,
}
post_counts_by_author_query () = Db.query (fun () -> {
  let p = from! posts
  group_by! [Db.group p.author_id]
  having! (Db.gt (Db.count p.id) 0)
  order_by! [Db.desc (Db.count p.id)]
  select! ({ author_id: p.author_id, total: Db.count p.id })
})

fun user_age_stats_query : Unit -> Db.Prepared {
  average_age: Maybe Float,
  oldest_age: Maybe Int,
  total_age: Maybe Int,
}
user_age_stats_query () = Db.query (fun () -> {
  let u = from! users
  select! ({
    average_age: Db.avg u.age,
    oldest_age: Db.max u.age,
    total_age: Db.sum u.age,
  })
})

fun user_posts_query : Unit -> Db.Prepared {
  post_title: String,
  user: User,
}
user_posts_query () = Db.query (fun () -> {
  let u = from! users
  let p = inner_join! posts (fun post -> Db.eq_col post.author_id u.id)
  where_! (Db.and_ [
    Db.eq u.name "Alice",
    Db.gt u.age 18,
    Db.eq p.published True,
    Db.expr_raw "? LIKE ?" [Db.sql p.title, Db.value "Hello%"],
  ])
  order_by! [Db.desc p.id]
  limit! 20
  select! ({ user: u, post_title: p.title })
})

# fun users_with_optional_posts_query : Unit -> Db.Prepared {
#   user: User,
#   post_id: Maybe Int,
#   post_title: Maybe String,
# }
users_with_optional_posts_query () = Db.query (fun () -> {
  let u = from! users
  let p = left_join! posts (fun post -> Db.eq_col post.author_id u.id)
  order_by! [Db.asc u.id]
  select! ({ user: u, post_id: p.id, post_title: p.title })
})

fun load_user_posts : Connection -> Result (List {
  post_title: String,
  user: User,
}) Db.DbError
  needs {Repo}
load_user_posts conn = Db.all conn (user_posts_query ())

fun load_users : Connection -> Result (List {
  id: Int,
  name: String,
  age: Int,
}) Db.DbError
  needs {Repo}
load_users conn = Db.all conn (users_query ())

fun load_user_age_stats : Connection -> Result (Maybe {
  average_age: Maybe Float,
  oldest_age: Maybe Int,
  total_age: Maybe Int,
}) Db.DbError
  needs {Repo}
load_user_age_stats conn = Db.one conn (user_age_stats_query ())

fun show_maybe_int : Maybe Int -> String
show_maybe_int value = case value {
  Just inner -> show inner
  Nothing -> "NULL"
}

fun show_maybe_float : Maybe Float -> String
show_maybe_float value = case value {
  Just inner -> show inner
  Nothing -> "NULL"
}

main () = {
  let config =
    { default_config "kraken_testing" |
      user: "postgres",
      password: "postgres",
      port: 5432,
    }
  let conn = connect config
  let users_prepared = users_query ()
  println users_prepared.sql

  let users_result = load_users conn with Db.pg_repo
  case users_result {
    Ok rows -> println ("users: " <> show (List.length rows))
    Err err -> println ("users query failed: " <> debug err)
  }

  let prepared = user_posts_query ()
  println prepared.sql

  let left_prepared = users_with_optional_posts_query ()
  println left_prepared.sql

  let grouped_prepared = post_counts_by_author_query ()
  println grouped_prepared.sql

  let stats_prepared = user_age_stats_query ()
  println stats_prepared.sql

  let stats_result = load_user_age_stats conn with Db.pg_repo
  case stats_result {
    Ok (Just stats) ->
      println $"age stats: avg={show_maybe_float stats.average_age} oldest={show_maybe_int stats.oldest_age} total={show_maybe_int stats.total_age}"
    Ok Nothing -> println "age stats: no row"
    Err err -> println ("stats query failed: " <> debug err)
  }

  let result = load_user_posts conn with Db.pg_repo

  case result {
    Ok rows -> {
      println ("rows: " <> show (List.length rows))
      List.iter (fun row ->
        println $"{show row.user.id}: {row.user.name}/{row.post_title}") rows
    }
    Err err -> println ("query failed: " <> debug err)
  }
} with {pg, console}
